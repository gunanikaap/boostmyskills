# ---------------------------------------------------------------------------
# Auth + user data (Supabase) — OPTIONAL.
#
# Leave these blank and the site runs in DEMO auth mode (no backend, nothing
# stored) so the repo clones-and-runs with zero setup.
#
# To enable real sign-in / registration (free, no credit card):
#   1. Create a project at https://supabase.com
#   2. Run supabase/schema.sql in the project's SQL editor
#   3. Project Settings -> API: copy the Project URL and the public "anon" key
#   4. Copy this file to .env.local and paste the two values below
#   5. Rebuild / restart (NEXT_PUBLIC_* vars are read at build time)
#
# The anon key is designed to be exposed in the browser. Never put the
# service_role key in a NEXT_PUBLIC_ variable.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Header auth-CTA destination — OPTIONAL.
#
# Controls where the header "Sign in" / "Register" buttons point:
#   local | demo  -> the in-site /login and /register pages (default)
#   external      -> the existing Open edX login/register URLs (handoff)
#
# Leave unset (or "local"/"demo") for development/presentation. Production
# deployments that want auth to hand off to Open edX should set:
#   NEXT_PUBLIC_AUTH_MODE=external
# NEXT_PUBLIC_* vars are read at build time, so set this before `npm run build`.
# Enrol buttons always link to Open edX regardless of this setting.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_MODE=local

# ---------------------------------------------------------------------------
# Auth backend for the in-site /login and /register pages — OPTIONAL.
#
# The clean in-site auth UI can run on different backends WITHOUT any UI change:
#   (unset)   -> Supabase if its keys are set, else the demo notice  [DEMO]
#   openedx   -> the university's existing Open edX backend           [PRODUCTION]
#
# Set this to "openedx" for production so registration/login use the real
# BoostMySkills (Open edX) accounts + activation email, then provide the three
# server-only credentials below (these are NOT NEXT_PUBLIC and never reach the
# browser). See HANDOFF.md and src/app/api/auth/openedx/route.ts.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_PROVIDER=
OPENEDX_LMS_URL=
OPENEDX_CLIENT_ID=
OPENEDX_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Contact-form email notification — OPTIONAL (server-only).
#
# The contact form ALWAYS stores submissions in the `contact_messages` table.
# Additionally email a notification on each submission ONLY if both of these are
# set (uses the Resend REST API; no SDK/dependency, no cost without these):
#   RESEND_API_KEY   a Resend API key (re_...)
#   CONTACT_NOTIFY_TO the inbox to notify, e.g. info@boostmyskills.eu
#   CONTACT_NOTIFY_FROM optional verified sender (defaults to onboarding@resend.dev)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
CONTACT_NOTIFY_TO=
CONTACT_NOTIFY_FROM=
